local function doSend()
    local msg=ib.Text; if msg=="" then return end; ib.Text=""
    if mode=="morse" then
        local mm=toMorse(msg)
        pcall(function()
            if TextChatService.TextChannels and TextChatService.TextChannels:FindFirstChild("RBXGeneral") then
                TextChatService.TextChannels.RBXGeneral:SendAsync(mm)
            else
                game.ReplicatedStorage:WaitForChild("DefaultChatSystemChatEvents").SayMessageRequest:FireServer(mm,"All")
            end
        end)
        addToLog(player.Name.." (You)",msg,false,false)
    else
        startSelfWatch()
        task.spawn(function() bodyMorseSend(msg) end)
    end
end
sb.MouseButton1Click:Connect(doSend)
ib.FocusLost:Connect(function(e) if e then doSend() end end)

local function onMsg(m)
    if not m.Text then return end
    local who=(m.TextSource and m.TextSource.Name) or "?"
    if looksLikeMorse(m.Text) then addToLog(who,m.Text,true,false)
    else addToLog(who,m.Text,false,false) end
end
if TextChatService.TextChannels then
    TextChatService.MessageReceived:Connect(onMsg)
end
pcall(function()
    game.ReplicatedStorage:WaitForChild("DefaultChatSystemChatEvents")
    .OnMessageDoneFiltering.OnClientEvent:Connect(function(d)
        onMsg({Text=d.Message,TextSource={Name=d.FromSpeaker}})
    end)
end)

