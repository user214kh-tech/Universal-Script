    l.Size = UDim2.new(1,0,0,0); l.AutomaticSize = Enum.AutomaticSize.Y
    l.BackgroundTransparency = 1; l.TextWrapped = true
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.RichText = true; l.Font = Enum.Font.Gotham; l.TextSize = 13
    if isMove then
        l.Text = string.format('<font color="#9B59B6">%s 🕹️:</font> <font color="#27AE60">%s</font>',sender,text)
    elseif isMorse then
        l.Text = string.format('<font color="#FF6B9D">%s:</font> <font color="#4ECDC4">%s</font> <font color="#C89EC0">(%s)</font>',sender,fromMorse(text),text)
    else
        l.Text = string.format('<font color="#FF6B9D">%s:</font> %s',sender,text)
    end
    task.defer(function() logFrame.CanvasPosition = Vector2.new(0,logFrame.AbsoluteCanvasSize.Y) end)
end

